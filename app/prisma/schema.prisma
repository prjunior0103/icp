generator client {
  provider        = "prisma-client-js"
  output          = "../app/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("COLABORADOR") // GUARDIAO, BP, GESTOR, COLABORADOR
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
}

model CicloICP {
  id        Int      @id @default(autoincrement())
  anoFiscal Int      @unique
  status    String   @default("SETUP") // SETUP, ATIVO, ENCERRADO
  mesInicio Int      @default(1)
  mesFim    Int      @default(12)
  bonusPool Float?
  criadoEm  DateTime @default(now())
}

model ParametroSistema {
  id           Int  @id @default(1)
  cicloAtivoId Int?
}

model Area {
  id           Int           @id @default(autoincrement())
  cicloId      Int
  centroCusto  String
  codEmpresa   String
  nivel1       String
  nivel2       String?
  nivel3       String?
  nivel4       String?
  nivel5       String?
  criadoEm     DateTime      @default(now())
  colaboradores Colaborador[]
}

model Colaborador {
  id               Int           @id @default(autoincrement())
  cicloId          Int
  areaId           Int?
  area             Area?         @relation(fields: [areaId], references: [id])
  nome             String
  email            String?
  matricula        String
  cargo            String
  grade            String?
  salarioBase      Float
  target           Float         // múltiplo salarial ex: 1.5
  centroCusto      String?
  codEmpresa       String?
  admissao         DateTime?
  gestorId         Int?
  gestor           Colaborador?  @relation("GestorSubordinados", fields: [gestorId], references: [id])
  subordinados     Colaborador[] @relation("GestorSubordinados")
  matriculaGestor  String?
  nomeGestor       String?
  status           String        @default("ATIVO") // ATIVO, INATIVO, AFASTADO
  criadoEm         DateTime      @default(now())
}
