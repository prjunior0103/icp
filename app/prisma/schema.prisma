generator client {
  provider        = "prisma-client-js"
  output          = "../app/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("COLABORADOR") // GUARDIAO, BP, GESTOR, COLABORADOR
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
}

model CicloICP {
  id        Int      @id @default(autoincrement())
  anoFiscal Int      @unique
  status    String   @default("SETUP") // SETUP, ATIVO, ENCERRADO
  mesInicio Int      @default(1)
  mesFim    Int      @default(12)
  bonusPool Float?
  criadoEm  DateTime @default(now())
}

model ParametroSistema {
  id           Int  @id @default(1)
  cicloAtivoId Int?
}
