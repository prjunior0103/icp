generator client {
  provider        = "prisma-client-js"
  output          = "../app/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

// ─── Auth / Users ────────────────────────────────────────────────────────────

model User {
  id             String        @id @default(uuid())
  email          String        @unique
  name           String
  passwordHash   String
  role           String        @default("COLABORADOR") // GUARDIAO, BP, GESTOR, COLABORADOR
  ativo          Boolean       @default(true)
  colaborador    Colaborador?
  workflowItems  WorkflowItem[]
  criadoEm       DateTime      @default(now())
}

// ─── Estrutura Organizacional ────────────────────────────────────────────────

model Empresa {
  id            Int           @id @default(autoincrement())
  codigo        String        @unique
  nome          String
  colaboradores Colaborador[]
  centrosCusto  CentroCusto[]
  ciclosSnapshot CicloColaborador[]
}

model CentroCusto {
  id            Int           @id @default(autoincrement())
  codigo        String        @unique
  nome          String
  nivel         Int           @default(1)
  empresa       Empresa       @relation(fields: [empresaId], references: [id])
  empresaId     Int
  colaboradores Colaborador[]
  metas         Meta[]
  ciclosSnapshot CicloColaborador[]
}

model Cargo {
  id               Int           @id @default(autoincrement())
  codigo           String        @unique
  nome             String
  nivelHierarquico String        @default("N4")
  targetMultiploSalarial  Float  @default(0)
  salarioTeto      Float?
  colaboradores    Colaborador[]
  ciclosSnapshot   CicloColaborador[]
}

model Colaborador {
  id               Int                @id @default(autoincrement())
  matricula        String             @unique
  nomeCompleto     String
  cpf              String             @unique
  email            String             @unique
  salarioBase      Float
  dataAdmissao     DateTime
  dataDesligamento DateTime?
  ativo            Boolean            @default(true)
  empresa          Empresa            @relation(fields: [empresaId], references: [id])
  empresaId        Int
  cargo            Cargo              @relation(fields: [cargoId], references: [id])
  cargoId          Int
  centroCusto      CentroCusto        @relation(fields: [centroCustoId], references: [id])
  centroCustoId    Int
  gestorId         Int?
  gestor           Colaborador?       @relation("GestorSubordinados", fields: [gestorId], references: [id])
  subordinados     Colaborador[]      @relation("GestorSubordinados")
  user             User?              @relation(fields: [userId], references: [id])
  userId           String?            @unique
  metas            MetaColaborador[]
  realizacoes      Realizacao[]
  movimentacoes    MovimentacaoRH[]
  atribuicoesAgrupamento AgrupamentoAtribuicao[] @relation("GestorAgrupamento")
  ciclosSnapshot         CicloColaborador[]
}

// ─── Ciclo ICP ───────────────────────────────────────────────────────────────

model CicloICP {
  id             Int              @id @default(autoincrement())
  anoFiscal      Int              @unique
  status         String           @default("SETUP") // SETUP, ATIVO, ENCERRADO
  mesInicio      Int              @default(1)
  mesFim         Int              @default(12)
  gatilhoEbitda  Float?
  bonusPool      Float?
  criadoEm       DateTime         @default(now())
  indicadores    Indicador[]
  metas          Meta[]
  janelas        JanelaApuracao[]
  agrupamentos   Agrupamento[]
  colaboradores  CicloColaborador[]
}

// ─── Snapshot histórico de colaboradores por ciclo ────────────────────────────

model CicloColaborador {
  id                     Int         @id @default(autoincrement())
  cicloId                Int
  ciclo                  CicloICP    @relation(fields: [cicloId], references: [id])
  colaboradorId          Int
  colaborador            Colaborador @relation(fields: [colaboradorId], references: [id])
  salarioBase            Float
  cargoId                Int
  cargo                  Cargo       @relation(fields: [cargoId], references: [id])
  targetMultiploSalarial Float
  centroCustoId          Int
  centroCusto            CentroCusto @relation(fields: [centroCustoId], references: [id])
  empresaId              Int
  empresa                Empresa     @relation(fields: [empresaId], references: [id])
  ativo                  Boolean     @default(true)
  criadoEm               DateTime    @default(now())

  @@unique([cicloId, colaboradorId])
  @@index([cicloId])
}

// ─── Indicadores ─────────────────────────────────────────────────────────────

model Indicador {
  id          Int       @id @default(autoincrement())
  codigo      String    @unique
  nome        String
  descricao   String?
  tipo              String    // VOLUME_FINANCEIRO, CUSTO_PRAZO, PROJETO_MARCO
  polaridade        String    @default("MAIOR_MELHOR") // MAIOR_MELHOR, MENOR_MELHOR
  abrangencia       String    // CORPORATIVO, AREA, INDIVIDUAL
  unidade           String    @default("%")
  metaMinima        Float?
  metaAlvo          Float?
  metaMaxima        Float?
  diretivo          String?   // Objetivo estratégico vinculado
  analistaResp      String?   // Analista responsável pelo indicador
  origemDado        String?   // Fonte/origem dos dados
  divisorId         Int?      // Indicador usado como divisor (ex: Receita Líquida)
  divisor           Indicador?  @relation("IndicadorDivisor", fields: [divisorId], references: [id])
  divisorado        Indicador[] @relation("IndicadorDivisor")
  ciclo             CicloICP  @relation(fields: [cicloId], references: [id])
  cicloId           Int
  metas             Meta[]
  status            String    @default("DRAFT") // DRAFT, ATIVO
  // Campos de governança e classificação
  baseline          Float?    // Linha de base — valor histórico de referência
  metrica           String?   // O que está sendo medido (ex: Receita Bruta, NPS)
  periodicidade     String?   // MENSAL | TRIMESTRAL | SEMESTRAL | ANUAL
  perspectiva       String?   // BSC: FINANCEIRA | CLIENTE | PROCESSOS | APRENDIZADO
  tipoIndicador     String?   // LEADING (processo) | LAGGING (resultado)
  auditorDados      String?   // Quem valida os dados enviados
  criterioApuracao  String?   @default("ULTIMA_POSICAO") // SOMA | MEDIA | ULTIMA_POSICAO
  faixas            FaixaAtingimento[]
  criadoEm          DateTime  @default(now())

  @@index([cicloId])
  @@index([status])
}

model FaixaAtingimento {
  id           Int       @id @default(autoincrement())
  indicador    Indicador @relation(fields: [indicadorId], references: [id], onDelete: Cascade)
  indicadorId  Int
  de           Float     // valor realizado >= de
  ate          Float     // valor realizado <= ate
  nota         Float     // % de atingimento (0-120)

  @@index([indicadorId])
}

// ─── Metas ───────────────────────────────────────────────────────────────────

model Meta {
  id              Int               @id @default(autoincrement())
  indicador       Indicador         @relation(fields: [indicadorId], references: [id])
  indicadorId     Int
  ciclo           CicloICP          @relation(fields: [cicloId], references: [id])
  cicloId         Int
  centroCusto     CentroCusto?      @relation(fields: [centroCustoId], references: [id])
  centroCustoId   Int?
  metaMinima         Float?
  metaAlvo           Float             @default(100)
  metaMaxima         Float?
  status             String            @default("DRAFT") // DRAFT, ATIVO, APROVADO, CANCELADO
  smart              String?           // JSON: {especifica, mensuravel, atingivel, relevante, temporal}
  // Campos opcionais de override por instância de meta
  nome               String?           // Nome próprio da meta (sobrescreve Indicador.nome)
  polaridade         String?           // MAIOR_MELHOR | MENOR_MELHOR (sobrescreve Indicador se preenchido)
  tipo               String?           // VOLUME_FINANCEIRO | CUSTO_PRAZO | PROJETO_MARCO (sobrescreve Indicador)
  unidade            String?           // %, R$, unidades (sobrescreve Indicador se preenchido)
  valorOrcado        Float?            // Valor orçado (budget) — específico desta meta
  parentMetaId    Int?              // Cascateamento: meta pai (corporativa/área)
  parentMeta      Meta?             @relation("MetaCascata", fields: [parentMetaId], references: [id])
  filhas          Meta[]            @relation("MetaCascata")
  colaboradores   MetaColaborador[]
  realizacoes     Realizacao[]
  workflowItems   WorkflowItem[]
  historico       MetaHistorico[]
  planosAcao      PlanoAcao[]
  agrupamentos    AgrupamentoMeta[]

  @@index([cicloId])
  @@index([indicadorId])
  @@index([parentMetaId])
}

model MetaHistorico {
  id         Int      @id @default(autoincrement())
  meta       Meta     @relation(fields: [metaId], references: [id])
  metaId     Int
  campo      String
  valorAntes String?
  valorDepois String?
  usuario    String?
  criadoEm  DateTime @default(now())
}

model PlanoAcao {
  id           Int       @id @default(autoincrement())
  meta         Meta      @relation(fields: [metaId], references: [id])
  metaId       Int
  descricao    String
  responsavel  String?
  prazo        DateTime?
  status       String    @default("ABERTO") // ABERTO, EM_ANDAMENTO, CONCLUIDO, CANCELADO
  criadoEm    DateTime  @default(now())
}

model BibliotecaMeta {
  id            Int     @id @default(autoincrement())
  nome          String
  descricao     String?
  indicadorNome String
  unidade       String  @default("%")
  tipo          String  // VOLUME_FINANCEIRO, CUSTO_PRAZO, PROJETO_MARCO, QUALITATIVO
  polaridade    String  @default("MAIOR_MELHOR")
  abrangencia   String  // CORPORATIVO, AREA, INDIVIDUAL
  metaMinima    Float?
  metaAlvo      Float?
  metaMaxima    Float?
  pesoSugerido  Float   @default(100)
  criadoEm     DateTime @default(now())
}

model MetaColaborador {
  id                Int         @id @default(autoincrement())
  meta              Meta        @relation(fields: [metaId], references: [id])
  metaId            Int
  colaborador       Colaborador @relation(fields: [colaboradorId], references: [id])
  colaboradorId     Int
  pesoPersonalizado Float?
  targetBonus       Float?
  ativo             Boolean     @default(true)

  @@unique([metaId, colaboradorId])
}

// ─── Agrupamentos de Metas ────────────────────────────────────────────────────

model Agrupamento {
  id                   Int                    @id @default(autoincrement())
  nome                 String
  descricao            String?
  tipo                 String                 // CORPORATIVO | AREA
  cicloId              Int
  ciclo                CicloICP               @relation(fields: [cicloId], references: [id])
  metas                AgrupamentoMeta[]
  atribuicoes          AgrupamentoAtribuicao[]
  // Suporte a cascateamento
  parentAgrupamentoId  Int?
  parentAgrupamento    Agrupamento?           @relation("AgrupamentoCascata", fields: [parentAgrupamentoId], references: [id])
  filhos               Agrupamento[]          @relation("AgrupamentoCascata")
  criadoEm             DateTime               @default(now())

  @@index([cicloId])
  @@index([parentAgrupamentoId])
}

model AgrupamentoMeta {
  id                    Int         @id @default(autoincrement())
  agrupamentoId         Int
  agrupamento           Agrupamento @relation(fields: [agrupamentoId], references: [id], onDelete: Cascade)
  metaId                Int
  meta                  Meta        @relation(fields: [metaId], references: [id])
  pesoNaCesta           Float       @default(0)   // peso desta meta dentro da cesta (soma das metas deve = 100)
  desceCascateamento    Boolean     @default(true) // se esta meta deve ser incluída no cascade

  @@unique([agrupamentoId, metaId])
}

model AgrupamentoAtribuicao {
  id              Int          @id @default(autoincrement())
  agrupamentoId   Int
  agrupamento     Agrupamento  @relation(fields: [agrupamentoId], references: [id], onDelete: Cascade)
  gestorId        Int?
  gestor          Colaborador? @relation("GestorAgrupamento", fields: [gestorId], references: [id])
  cascatear       Boolean      @default(false)
  aplicadoEm      DateTime?
  criadoEm        DateTime     @default(now())

  @@unique([agrupamentoId, gestorId])
}

// ─── Realizações ─────────────────────────────────────────────────────────────

model Realizacao {
  id               Int          @id @default(autoincrement())
  meta             Meta         @relation(fields: [metaId], references: [id])
  metaId           Int
  colaborador      Colaborador? @relation(fields: [colaboradorId], references: [id])
  colaboradorId    Int?
  mesReferencia    Int
  anoReferencia    Int
  valorRealizado   Float
  orcadoMensal     Float?    // orçado distribuído para este mês
  dataRealizada    String?   // para tipo Marco (ISO date YYYY-MM-DD)
  notaCalculada    Float?
  premioProjetado  Float?
  evidenciaUrl     String?
  observacao       String?
  valorDividendo   Float?    // componente numerador (quando indicador tem divisorId)
  valorDivisor     Float?    // componente denominador (quando indicador tem divisorId)
  status           String       @default("RASCUNHO") // RASCUNHO, SUBMETIDO, APROVADO, REJEITADO
  submissao        DateTime?
  aprovacao        DateTime?
  workflowItems    WorkflowItem[]

  @@unique([metaId, colaboradorId, mesReferencia, anoReferencia])
  @@index([metaId])
  @@index([colaboradorId])
  @@index([anoReferencia, mesReferencia])
}

// ─── Janela de Apuração ───────────────────────────────────────────────────────

model JanelaApuracao {
  id              Int                 @id @default(autoincrement())
  ciclo           CicloICP            @relation(fields: [cicloId], references: [id])
  cicloId         Int
  mesReferencia   Int
  anoReferencia   Int
  dataAbertura    DateTime
  dataFechamento  DateTime
  status          String              @default("ABERTA") // ABERTA, FECHADA, PRORROGADA
  prorrogacoes    ProrrogacaoWaiver[]

  @@unique([cicloId, mesReferencia, anoReferencia])
  @@index([cicloId])
}

model ProrrogacaoWaiver {
  id              Int            @id @default(autoincrement())
  janela          JanelaApuracao @relation(fields: [janelaId], references: [id])
  janelaId        Int
  colaboradorId   Int
  justificativa   String
  novaDataLimite  DateTime
  status          String         @default("PENDENTE") // PENDENTE, APROVADO, REJEITADO
  criadoEm        DateTime       @default(now())
  resolvidoEm     DateTime?
}

// ─── Workflow ─────────────────────────────────────────────────────────────────

model WorkflowItem {
  id            Int          @id @default(autoincrement())
  tipo          String       // META_NOVA, ALTERACAO_META, REALIZACAO, PRORROGACAO, MOVIMENTACAO_RH
  status        String       @default("PENDENTE") // PENDENTE, APROVADO, REJEITADO
  descricao     String
  metaId        Int?
  meta          Meta?        @relation(fields: [metaId], references: [id])
  realizacaoId  Int?
  realizacao    Realizacao?  @relation(fields: [realizacaoId], references: [id])
  solicitanteId String
  solicitante   User         @relation(fields: [solicitanteId], references: [id])
  comentario    String?
  criadoEm      DateTime     @default(now())
  resolvidoEm   DateTime?

  @@index([status])
  @@index([metaId])
  @@index([realizacaoId])
}

// ─── Movimentações RH ─────────────────────────────────────────────────────────

model MovimentacaoRH {
  id              Int         @id @default(autoincrement())
  colaborador     Colaborador @relation(fields: [colaboradorId], references: [id])
  colaboradorId   Int
  tipo            String      // ADMISSAO, TRANSFERENCIA, PROMOCAO, DESLIGAMENTO
  dataEfetiva     DateTime
  cargoAnteriorId Int?
  cargoNovoId     Int?
  ccAnteriorId    Int?
  ccNovoId        Int?
  status          String      @default("PENDENTE")
  criadoEm        DateTime    @default(now())
}

// ─── Parâmetro Sistema ────────────────────────────────────────────────────────

model ParametroSistema {
  id           Int     @id @default(1)
  seeded       Boolean @default(false)
  cicloAtivoId Int?
}
