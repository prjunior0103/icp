generator client {
  provider        = "prisma-client-js"
  output          = "../app/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("COLABORADOR") // GUARDIAO, BP, GESTOR, COLABORADOR
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
}

model CicloICP {
  id        Int      @id @default(autoincrement())
  anoFiscal Int      @unique
  status    String   @default("SETUP") // SETUP, ATIVO, ENCERRADO
  mesInicio Int      @default(1)
  mesFim    Int      @default(12)
  bonusPool Float?
  criadoEm  DateTime @default(now())
}

model ParametroSistema {
  id           Int  @id @default(1)
  cicloAtivoId Int?
}

model Area {
  id           Int           @id @default(autoincrement())
  cicloId      Int
  centroCusto  String
  codEmpresa   String
  nivel1       String
  nivel2       String?
  nivel3       String?
  nivel4       String?
  nivel5       String?
  criadoEm     DateTime      @default(now())
  colaboradores Colaborador[]
}

model Colaborador {
  id               Int                    @id @default(autoincrement())
  cicloId          Int
  areaId           Int?
  area             Area?                  @relation(fields: [areaId], references: [id])
  nome             String
  email            String?
  matricula        String
  cargo            String
  grade            String?
  salarioBase      Float
  target           Float
  centroCusto      String?
  codEmpresa       String?
  admissao         DateTime?
  gestorId         Int?
  gestor           Colaborador?           @relation("GestorSubordinados", fields: [gestorId], references: [id])
  subordinados     Colaborador[]          @relation("GestorSubordinados")
  matriculaGestor  String?
  nomeGestor       String?
  status           String                 @default("ATIVO")
  criadoEm         DateTime               @default(now())
  atribuicoes      AtribuicaoAgrupamento[]
  indicadoresResp  Indicador[]            @relation("ResponsavelEnvio")
}

model Indicador {
  id                  Int                    @id @default(autoincrement())
  cicloId             Int
  codigo              String
  nome                String
  descricao           String?
  tipo                String                 // MAIOR_MELHOR | MENOR_MELHOR | PROJETO_MARCO
  abrangencia         String                 @default("CORPORATIVO") // CORPORATIVO | AREA | INDIVIDUAL
  unidade             String                 @default("%")
  metaMinima          Float?
  metaAlvo            Float?
  metaMaxima          Float?
  baseline            Float?
  metrica             String?
  periodicidade       String                 @default("MENSAL") // MENSAL | TRIMESTRAL | SEMESTRAL | ANUAL
  criterioApuracao    String                 @default("ULTIMA_POSICAO") // SOMA | MEDIA | ULTIMA_POSICAO
  origemDado          String?
  analistaResp        String?
  aprovadorId         String?                // User.id
  responsavelEnvioId  Int?
  responsavelEnvio    Colaborador?           @relation("ResponsavelEnvio", fields: [responsavelEnvioId], references: [id])
  numeradorId         Int?
  numerador           Indicador?             @relation("IndicadorNumerador", fields: [numeradorId], references: [id])
  numerados           Indicador[]            @relation("IndicadorNumerador")
  divisorId           Int?
  divisor             Indicador?             @relation("IndicadorDivisor", fields: [divisorId], references: [id])
  divisorado          Indicador[]            @relation("IndicadorDivisor")
  statusJanela        String                 @default("FECHADA") // ABERTA | FECHADA | PRORROGADA
  janelaAbertaEm      DateTime?
  janelaFechadaEm     DateTime?
  status              String                 @default("DRAFT") // DRAFT | ATIVO
  criadoEm            DateTime               @default(now())
  indicadoresGrupo    IndicadorNoAgrupamento[]
  faixas              FaixaIndicador[]
  realizacoes         Realizacao[]
  metasPeriodo        MetaPeriodo[]

  @@unique([cicloId, codigo])
}

model Agrupamento {
  id          Int                    @id @default(autoincrement())
  cicloId     Int
  nome        String
  tipo        String                 @default("CORPORATIVO") // CORPORATIVO | AREA
  descricao   String?
  criadoEm    DateTime               @default(now())
  indicadores IndicadorNoAgrupamento[]
  atribuicoes AtribuicaoAgrupamento[]
}

model IndicadorNoAgrupamento {
  id            Int         @id @default(autoincrement())
  agrupamentoId Int
  agrupamento   Agrupamento @relation(fields: [agrupamentoId], references: [id], onDelete: Cascade)
  indicadorId   Int
  indicador     Indicador   @relation(fields: [indicadorId], references: [id])
  peso          Float       @default(0)

  @@unique([agrupamentoId, indicadorId])
}

model AtribuicaoAgrupamento {
  id              Int          @id @default(autoincrement())
  cicloId         Int
  colaboradorId   Int
  colaborador     Colaborador  @relation(fields: [colaboradorId], references: [id])
  agrupamentoId   Int
  agrupamento     Agrupamento  @relation(fields: [agrupamentoId], references: [id])
  pesoNaCesta     Float
  cascata         String       @default("NENHUM") // NENHUM | DIRETOS | DIRETOS_E_INDIRETOS
  criadoEm        DateTime     @default(now())

  @@unique([colaboradorId, agrupamentoId])
}

model Realizacao {
  id             Int       @id @default(autoincrement())
  cicloId        Int
  indicadorId    Int
  indicador      Indicador @relation(fields: [indicadorId], references: [id], onDelete: Cascade)
  periodo        String    // "2025-01" | "2025-T1" | "2025-S1" | "2025"
  valorRealizado Float
  lancadoPor     String?
  dataEnvio      DateTime?
  anexoPath      String?
  criadoEm       DateTime  @default(now())

  @@unique([indicadorId, periodo])
}

model MetaPeriodo {
  id          Int       @id @default(autoincrement())
  cicloId     Int
  indicadorId Int
  indicador   Indicador @relation(fields: [indicadorId], references: [id], onDelete: Cascade)
  periodo     String
  valorOrcado Float
  criadoEm    DateTime  @default(now())

  @@unique([indicadorId, periodo])
}

model FaixaIndicador {
  id          Int       @id @default(autoincrement())
  indicadorId Int
  indicador   Indicador @relation(fields: [indicadorId], references: [id], onDelete: Cascade)
  de          Float
  ate         Float
  nota        Float

  @@unique([indicadorId, de])
}
